<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- относительный путь -->
    <property name="LOG_DIR" value="logs"/>
    <property name="WEEKLY_LOG" value="${LOG_DIR}/replenishment.log"/>

    <!-- отдельный файл только для загрузчика -->
    <appender name="WEEKLY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${WEEKLY_LOG}</file>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{50} - %msg%n</pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archive/weekly-data-loader-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- только твой класс -->
    <logger name="ru.stockmann.replenishment.storeturnover.services.WeeklyDataBulkLoader"
            level="INFO"
            additivity="true">
        <appender-ref ref="WEEKLY_FILE"/>
    </logger>

</configuration>